ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CryptoSwift" "${PODS_CONFIGURATION_BUILD_DIR}/DifferenceKit" "${PODS_CONFIGURATION_BUILD_DIR}/GCDWebServer" "${PODS_CONFIGURATION_BUILD_DIR}/Minizip" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumFuzi" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumInternal" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumNavigator" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumShared" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumStreamer" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumZIPFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/SwiftSoup" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation" "${PODS_ROOT}/ffmpeg-kit-ios-full/ffmpeg-kit-ios-full" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ffmpeg-kit-ios-full"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CryptoSwift/CryptoSwift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/DifferenceKit/DifferenceKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/GCDWebServer/GCDWebServer.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Minizip/Minizip.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumFuzi/ReadiumFuzi.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumInternal/ReadiumInternal.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumNavigator/ReadiumNavigator.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumShared/ReadiumShared.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumStreamer/ReadiumStreamer.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReadiumZIPFoundation/ReadiumZIPFoundation.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/SwiftSoup/SwiftSoup.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation/ZIPFoundation.framework/Headers" $(SDKROOT)/usr/include/libxml2
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_LDFLAGS = $(inherited) -ObjC -l"xml2" -l"z" -framework "CFNetwork" -framework "CoreServices" -framework "CryptoSwift" -framework "DifferenceKit" -framework "GCDWebServer" -framework "Minizip" -framework "MobileCoreServices" -framework "ReadiumFuzi" -framework "ReadiumInternal" -framework "ReadiumNavigator" -framework "ReadiumShared" -framework "ReadiumStreamer" -framework "ReadiumZIPFoundation" -framework "SwiftSoup" -framework "UIKit" -framework "ZIPFoundation" -framework "ffmpegkit" -framework "libavcodec" -framework "libavdevice" -framework "libavfilter" -framework "libavformat" -framework "libavutil" -framework "libswresample" -framework "libswscale"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/CryptoSwift" "-F${PODS_CONFIGURATION_BUILD_DIR}/DifferenceKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/GCDWebServer" "-F${PODS_CONFIGURATION_BUILD_DIR}/Minizip" "-F${PODS_CONFIGURATION_BUILD_DIR}/ReadiumFuzi" "-F${PODS_CONFIGURATION_BUILD_DIR}/ReadiumInternal" "-F${PODS_CONFIGURATION_BUILD_DIR}/ReadiumNavigator" "-F${PODS_CONFIGURATION_BUILD_DIR}/ReadiumShared" "-F${PODS_CONFIGURATION_BUILD_DIR}/ReadiumStreamer" "-F${PODS_CONFIGURATION_BUILD_DIR}/ReadiumZIPFoundation" "-F${PODS_CONFIGURATION_BUILD_DIR}/SwiftSoup" "-F${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation" "-F${PODS_CONFIGURATION_BUILD_DIR}/ffmpeg-kit-ios-full"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
